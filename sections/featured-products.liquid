{% assign fp_col = collections[section.settings.collection] %}
{% if fp_col == blank or fp_col.products_count == 0 %}
  {% assign fp_col = collections.all %}
{% endif %}

{% if fp_col.products_count > 0 %}
<section class="products-section">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="section-title">{{ section.settings.title }} <span class="gradient-text">{{ section.settings.title_highlight }}</span></h2>
      <p class="section-desc">{{ section.settings.description }}</p>
    </div>
    <div class="products-grid stagger">
      {% for product in fp_col.products limit: section.settings.product_limit %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>
    <div style="text-align:center;margin-top:48px;">
      <a href="{{ section.settings.cta_url }}" class="btn btn-outline">
        {{ section.settings.cta_label }}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Most Popular" },
    { "type": "text", "id": "title", "label": "Title", "default": "The Ones" },
    { "type": "text", "id": "title_highlight", "label": "Title highlight", "default": "Everyone's Running" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "The products showing up in every setup tour, every stream overlay, every desk photo worth saving." },
    { "type": "collection", "id": "collection", "label": "Collection to feature" },
    {
      "type": "range", "id": "product_limit", "label": "Number of products",
      "min": 2, "max": 12, "step": 2, "default": 8
    },
    { "type": "text", "id": "cta_label", "label": "CTA button label", "default": "View All Products" },
    { "type": "url", "id": "cta_url", "label": "CTA button URL" }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
