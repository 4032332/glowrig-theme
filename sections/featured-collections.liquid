<section class="collections-section">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="section-title">{{ section.settings.title }} <span class="gradient-text">{{ section.settings.title_highlight }}</span></h2>
      <p class="section-desc">{{ section.settings.description }}</p>
    </div>
    <div class="collections-grid stagger">
      {% for block in section.blocks %}
        {% assign col = collections[block.settings.collection] %}
        {% assign col_img = nil %}
        {% if col.featured_image %}
          {% assign col_img = col.featured_image %}
        {% elsif col.products.first.featured_image %}
          {% assign col_img = col.products.first.featured_image %}
        {% endif %}
        <a href="{{ block.settings.url }}" class="collection-card {{ block.settings.theme }}" style="text-decoration:none;" {{ block.shopify_attributes }}>
          <div class="collection-card-bg">
            {% if col_img %}
              <img
                src="{{ col_img | image_url: width: 700 }}"
                alt="{{ col_img.alt | default: block.settings.name | escape }}"
                width="700"
                height="700"
                loading="lazy"
                style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;"
              >
              <div style="position:absolute;inset:0;z-index:1;background:linear-gradient(to bottom,rgba(10,10,15,0.25) 0%,rgba(10,10,15,0.75) 60%,rgba(10,10,15,0.92) 100%);"></div>
            {% else %}
              <div style="position:absolute;inset:0;background:{{ block.settings.bg_gradient }};z-index:0;"></div>
              <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:80px;opacity:0.3;z-index:1;">{{ block.settings.emoji }}</div>
            {% endif %}
          </div>
          <div class="collection-card-overlay"></div>
          <div class="collection-card-content">
            <span class="collection-tag">{{ block.settings.tag }}</span>
            <h3 class="collection-name">{{ block.settings.name }}</h3>
            <span class="collection-count">{{ block.settings.subtitle }}</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collections",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Browse by Category" },
    { "type": "text", "id": "title", "label": "Title", "default": "Build Your" },
    { "type": "text", "id": "title_highlight", "label": "Title highlight", "default": "Dream Setup" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Every product curated for one purpose — making your desk look and feel exactly the way you've imagined it." }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection (for image)" },
        { "type": "url", "id": "url", "label": "Link URL" },
        {
          "type": "select", "id": "theme", "label": "Colour theme",
          "options": [
            { "value": "theme-purple", "label": "Purple" },
            { "value": "theme-cyan", "label": "Cyan" }
          ],
          "default": "theme-purple"
        },
        { "type": "text", "id": "bg_gradient", "label": "Fallback gradient (CSS)", "default": "linear-gradient(135deg,#0d0015 0%,#2a0050 50%,#0a001a 100%)" },
        { "type": "text", "id": "emoji", "label": "Fallback emoji", "default": "🌌" },
        { "type": "text", "id": "tag", "label": "Tag label", "default": "Foundation" },
        { "type": "text", "id": "name", "label": "Collection name", "default": "Desk Mats" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Cosmic & Japanese Series" }
      ]
    }
  ],
  "presets": [{ "name": "Featured Collections" }]
}
{% endschema %}
