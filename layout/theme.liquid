<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="{{ page_description | default: 'GlowRig — Level up your setup. Premium gaming desk accessories, RGB lighting, desk mats and more. Fast shipping Australia-wide.' }}">
  <title>{{ page_title }}{% if page_title != shop.name %} — {{ shop.name }}{% endif %}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  {{ content_for_header }}
  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
</head>
<body>
  <div class="announcement-bar">
    <div class="container">
      <span class="announcement-text">⚡ Free shipping on orders over $75 — Fast AU delivery</span>
    </div>
  </div>

  <header class="site-header">
    <div class="container">
      <div class="header-inner">
        <a href="{{ routes.root_url }}" class="site-logo" aria-label="{{ shop.name }}">
          <svg class="logo-mark" width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="logoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#b44fff"/>
                <stop offset="100%" style="stop-color:#00f5ff"/>
              </linearGradient>
              <filter id="logoGlow"><feGaussianBlur stdDeviation="1.5" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
            </defs>
            <rect x="1" y="1" width="34" height="34" rx="6" stroke="url(#logoGrad)" stroke-width="1.5" fill="none"/>
            <path d="M20 4L10 19H17L14 32L26 15H19L20 4Z" fill="url(#logoGrad)" filter="url(#logoGlow)"/>
          </svg>
          <span class="logo-text">GlowRig</span>
        </a>

        <nav class="site-nav" aria-label="Main navigation">
          <a href="{{ routes.root_url }}" class="nav-link">Home</a>
          <a href="{{ routes.all_products_collection_url }}" class="nav-link">Shop All</a>
          <a href="{{ routes.collections_url }}/desk-mats" class="nav-link">Desk Mats</a>
          <a href="{{ routes.collections_url }}/lighting" class="nav-link">Lighting</a>
          <a href="{{ routes.collections_url }}/organisation" class="nav-link">Organisation</a>
          <a href="{{ routes.collections_url }}/bundles" class="nav-link">Bundles</a>
        </nav>

        <div class="header-actions">
          <button class="header-icon-btn" data-search-open aria-label="Search">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </button>
          <button class="header-icon-btn cart-count" data-cart-open aria-label="Cart">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span class="cart-badge" style="display:none">0</span>
          </button>
          <button class="mobile-menu-btn" aria-label="Menu"><span></span><span></span><span></span></button>
        </div>
      </div>
    </div>
  </header>

  <!-- Mobile nav drawer -->
  <div class="mobile-nav-overlay"></div>
  <div class="mobile-nav">
    <a href="{{ routes.root_url }}" class="mobile-nav-link">Home</a>
    <a href="{{ routes.all_products_collection_url }}" class="mobile-nav-link">Shop All</a>
    <a href="{{ routes.collections_url }}/desk-mats" class="mobile-nav-link">Desk Mats</a>
    <a href="{{ routes.collections_url }}/lighting" class="mobile-nav-link">Lighting</a>
    <a href="{{ routes.collections_url }}/organisation" class="mobile-nav-link">Organisation</a>
    <a href="{{ routes.collections_url }}/bundles" class="mobile-nav-link">Bundles</a>
  </div>

  <main id="main-content" tabindex="-1">{{ content_for_layout }}</main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <span class="logo-text" style="display:block;margin-bottom:16px;">GlowRig</span>
          <p class="footer-tagline">Premium gaming setup accessories for the aesthetic-first gamer. Desk mats, RGB lighting, stands and bundles — shipped fast across Australia.</p>
          <div class="footer-social">
            <a href="#" class="social-link" aria-label="TikTok">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-6.13 6.3 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg>
            </a>
            <a href="#" class="social-link" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
            <a href="#" class="social-link" aria-label="YouTube">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg>
            </a>
          </div>
        </div>
        <div>
          <h3 class="footer-heading">Shop</h3>
          <ul class="footer-links">
            <li><a href="{{ routes.all_products_collection_url }}">All Products</a></li>
            <li><a href="{{ routes.collections_url }}/desk-mats">Desk Mats</a></li>
            <li><a href="{{ routes.collections_url }}/lighting">Lighting</a></li>
            <li><a href="{{ routes.collections_url }}/organisation">Organisation</a></li>
            <li><a href="{{ routes.collections_url }}/bundles">Bundles</a></li>
          </ul>
        </div>
        <div>
          <h3 class="footer-heading">Help</h3>
          <ul class="footer-links">
            <li><a href="/pages/shipping">Shipping Info</a></li>
            <li><a href="/pages/returns">Returns & Refunds</a></li>
            <li><a href="/pages/faq">FAQ</a></li>
            <li><a href="/pages/contact">Contact Us</a></li>
          </ul>
        </div>
        <div>
          <h3 class="footer-heading">Legal</h3>
          <ul class="footer-links">
            <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
            <li><a href="/policies/terms-of-service">Terms of Service</a></li>
            <li><a href="/policies/refund-policy">Refund Policy</a></li>
            <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© {{ 'now' | date: '%Y' }} GlowRig. All rights reserved.</span>
        <span>Made with 🎮 in Australia</span>
      </div>
    </div>
  </footer>

  <div class="cart-drawer-overlay" data-cart-close></div>
  <div class="cart-drawer" role="dialog" aria-label="Shopping cart" aria-modal="true">
    <div class="cart-drawer-header">
      <h2 class="cart-drawer-title">Your Cart <span class="cart-drawer-count" id="cart-drawer-count"></span></h2>
      <button class="cart-drawer-close" data-cart-close aria-label="Close cart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="cart-drawer-body" id="cart-drawer-items">{% render 'cart-drawer-items' %}</div>
    <div class="cart-drawer-footer" id="cart-drawer-footer">
      <div class="cart-drawer-free-ship" id="cart-drawer-ship-bar">
        {% if cart.total_price < 7500 %}
          <div class="ship-bar-text">Add <strong>{{ 7500 | minus: cart.total_price | money }}</strong> for free shipping</div>
          <div class="ship-bar-track"><div class="ship-bar-fill" style="width:{{ cart.total_price | times: 100 | divided_by: 7500 | at_most: 100 }}%"></div></div>
        {% else %}
          <div class="ship-bar-text ship-bar-done">✓ You qualify for free shipping!</div>
        {% endif %}
      </div>
      <div class="cart-drawer-summary">
        <div class="cart-drawer-row"><span>Subtotal</span><span id="cart-drawer-subtotal">{{ cart.total_price | money }}</span></div>
        <div class="cart-drawer-row cart-drawer-row--muted"><span>Shipping</span><span>Calculated at checkout</span></div>
      </div>
      <form action="{{ routes.cart_url }}" method="post">
        <input type="hidden" name="checkout" value="1">
        <button type="submit" class="btn btn-primary btn-full cart-drawer-checkout">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Checkout Securely
        </button>
      </form>
      <button class="cart-drawer-continue" data-cart-close>Continue Shopping</button>
    </div>
  </div>

  <div class="search-overlay" role="dialog" aria-label="Search">
    <div class="search-box">
      <button data-search-close style="position:absolute;top:40px;right:24px;background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:14px;font-family:var(--font-heading);">ESC</button>
      <form action="{{ routes.search_url }}" method="get">
        <input type="search" name="q" class="search-input" placeholder="Search desk mats, lighting, stands..." autocomplete="off">
      </form>
    </div>
  </div>

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
