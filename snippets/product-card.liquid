<div class="product-card">
  <div class="product-card-image">
    {% if product.featured_image %}
      <img src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" loading="lazy" width="600" height="600">
    {% else %}
      <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:var(--text-muted);font-size:40px;">🎮</div>
    {% endif %}
    {% if product.tags contains 'hot' %}<span class="product-badge badge-hot">🔥 Hot</span>{% endif %}
    <div class="product-quick-add">
      <button class="btn btn-outline btn-full" data-quick-add data-variant-id="{{ product.selected_or_first_available_variant.id }}" style="font-size:12px;padding:10px 16px;background:rgba(10,10,15,0.9);backdrop-filter:blur(8px);">Quick Add</button>
    </div>
  </div>
  <div class="product-card-body">
    <div class="product-collection">{% if product.collections.first %}{{ product.collections.first.title }}{% else %}GlowRig{% endif %}</div>
    <a href="{{ product.url }}" style="text-decoration:none;color:inherit;"><h3 class="product-title">{{ product.title }}</h3></a>
    <div class="product-price-row">
      <span class="product-price">{{ product.price | money }}</span>
      {% if product.variants.size > 1 %}
        <div class="product-variants">
          {% for variant in product.variants limit: 4 %}
            <div class="variant-dot" title="{{ variant.title }}" style="background:{% if variant.title contains 'Black' %}#1a1a1a{% elsif variant.title contains 'White' %}#f0f0f0{% elsif variant.title contains 'Pink' %}#ff44aa{% else %}var(--accent-purple){% endif %};"></div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>
