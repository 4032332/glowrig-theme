{% comment %}
  Product Card Snippet
  Usage: {% render 'product-card', product: product %}
{% endcomment %}

<div class="product-card">
  <div class="product-card-image">
    {% if product.featured_image %}
      <img
        src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        loading="lazy"
        width="600"
        height="600"
      >
    {% else %}
      <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:var(--text-muted);">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      </div>
    {% endif %}

    {% if product.created_at > 'now' | date: '%s' | minus: 2592000 | date: '%Y-%m-%dT%H:%M:%SZ' %}
      <span class="product-badge badge-new">New</span>
    {% endif %}

    {% if product.tags contains 'hot' %}
      <span class="product-badge badge-hot">🔥 Hot</span>
    {% endif %}

    <div class="product-quick-add">
      <button
        class="btn btn-outline btn-full"
        data-quick-add
        data-variant-id="{{ product.selected_or_first_available_variant.id }}"
        style="font-size:12px;padding:10px 16px;background:rgba(10,10,15,0.9);backdrop-filter:blur(8px);"
      >
        Quick Add
      </button>
    </div>
  </div>

  <div class="product-card-body">
    {% if product.collections.first %}
      <div class="product-collection">{{ product.collections.first.title }}</div>
    {% else %}
      <div class="product-collection">GlowRig</div>
    {% endif %}

    <a href="{{ product.url }}" style="text-decoration:none;color:inherit;">
      <h3 class="product-title">{{ product.title }}</h3>
    </a>

    <div class="product-price-row">
      <span class="product-price">{{ product.price | money }}</span>

      {% if product.variants.size > 1 %}
        <div class="product-variants">
          {% for variant in product.variants limit: 4 %}
            <div class="variant-dot" title="{{ variant.title }}"
              style="background:{% if variant.title contains 'Black' %}#1a1a1a{% elsif variant.title contains 'White' %}#f0f0f0{% elsif variant.title contains 'Pink' %}#ff44aa{% else %}var(--accent-purple){% endif %};border-color:transparent;">
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>
